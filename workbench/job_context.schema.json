{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fjjky.local/schemas/bridge-monitoring-job-context-v2.json",
  "title": "Bridge Monitoring Workbench Job Context",
  "type": "object",
  "required": [
    "schema_version", "job_id", "app_version", "project_root", "bridge_id",
    "data_root", "start_date", "end_date", "config_path", "config_sha256",
    "selected_modules", "options", "analysis", "report"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "job_id": {"type": "string", "minLength": 1},
    "app_version": {"type": "string", "minLength": 1},
    "bridge_id": {"type": "string", "minLength": 1},
    "data_root": {"type": "string", "minLength": 1},
    "start_date": {"type": "string", "format": "date"},
    "end_date": {"type": "string", "format": "date"},
    "selected_modules": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "options": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "analysis": {
      "type": "object",
      "properties": {"manifest_sha256": {"type": "string"}}
    },
    "report": {
      "type": "object",
      "properties": {
        "template_sha256": {"type": "string"},
        "derived_artifact_manifest_path": {"type": "string"},
        "derived_artifact_manifest_sha256": {"type": "string"},
        "stdout_log": {"type": "string"},
        "stderr_log": {"type": "string"},
        "pid": {"type": ["integer", "null"]}
      }
    }
  }
}
